# Server
NODE_ENV=production
# Railway injects PORT automatically. Only set PORT locally if needed.
# PORT=3000
# Optional: set your deployed app URL for password reset links.
#PUBLIC_APP_URL=https://your-app.up.railway.app

# Auth
JWT_SECRET=replace_with_a_long_random_secret_32_plus_chars

# OpenAI
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=replace_with_supabase_service_role_key

# Email Notifications
RESEND_API_KEY=replace_with_resend_api_key
EMAIL_FROM=Atlas Wellness <onboarding@resend.dev>

# Optional admin seed
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=replace_with_strong_password
